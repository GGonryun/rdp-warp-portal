# RDP Broker Configuration
# Copy this file to .env and customize as needed

# --- API ---
API_PORT=8080
# JWT secret for API authentication (empty = dev mode, accepts any token)
API_JWT_SECRET=

# --- Broker ---
# Public hostname/IP that RDP clients will connect to
BROKER_HOST=YOUR_PUBLIC_IP_OR_HOSTNAME
# Domain shown in RDP file (cosmetic)
BROKER_DOMAIN=YOURORG

# --- Proxy ports ---
# Port range for gatekeeper listeners (one port per concurrent session)
PROXY_PORT_START=33400
PROXY_PORT_END=33410
# Offset for internal proxy ports (external + offset = internal)
PROXY_INTERNAL_OFFSET=11000

# --- Credential provider ---
# Provider type: mock | vault | aws | custom
CREDENTIAL_PROVIDER=mock
# Path to targets config JSON (see .targets.json.example)
CREDENTIAL_PROVIDER_CONFIG=/etc/rdp-broker/targets.json

# --- Security overrides (DEVELOPMENT ONLY) ---
# These must be explicitly set to use development/test configurations
ALLOW_MOCK_PROVIDER=true
ALLOW_INSECURE_AUTH=true

# --- Paths ---
CERT_DIR=/etc/rdp-broker/certs
SESSION_DIR=/tmp/sessions
FREERDP_PROXY_BIN=freerdp-proxy

# --- Session policy ---
MAX_CONCURRENT_SESSIONS=10
SESSION_MAX_DURATION=8h
TOKEN_TTL=5m

# --- Logging ---
# Log level: debug | info | warn | error
LOG_LEVEL=debug
# Log format: json | text
LOG_FORMAT=json
# Optional audit log file path
AUDIT_LOG_FILE=
