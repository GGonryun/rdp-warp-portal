# RDP Broker Configuration

# Public hostname/IP that RDP clients will connect to (REQUIRED)
BROKER_HOST=YOUR_PUBLIC_IP

# API key for authenticating all /api/ requests (Bearer token)
# Leave empty to disable auth
API_KEY=your-secret-api-key

# Log level: debug | info | warn | error (optional, default: info)
LOG_LEVEL=info

# Azure Workload Identity Federation (optional — all three must be set to enable)
AZURE_CREDENTIAL_URL=
GCP_WIF_AUDIENCE=
GCP_SERVICE_ACCOUNT=
